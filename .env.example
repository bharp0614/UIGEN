# Database
# For local Docker: postgresql://uigen:uigen@localhost:5432/uigen
# For Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://uigen:uigen@localhost:5432/uigen

# JWT secret for auth sessions (generate a random string for production)
JWT_SECRET=development-secret-key

# Optional: Anthropic API key for real AI generation
# Leave blank or use the placeholder to use the mock provider
ANTHROPIC_API_KEY=your-api-key-here
